# Caddy auto-issues + auto-renews Let's Encrypt certs.
# Change distrebute.com / api.distrebute.com to YOUR domains.

# Frontend
distrebute.com {
    encode gzip zstd
    reverse_proxy localhost:3000

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        Permissions-Policy "geolocation=(), camera=(), microphone=()"
        Content-Security-Policy "default-src 'self'; img-src 'self' https: data:; media-src 'self' https://cdn.distrebute.com; connect-src 'self' https://api.distrebute.com wss://api.distrebute.com; frame-ancestors 'none';"
    }
}

# API gateway
api.distrebute.com {
    encode gzip zstd

    # Strip /api/v1 prefix and route by path
    handle /api/v1/auth/* {
        uri strip_prefix /api/v1
        reverse_proxy localhost:8001
    }
    handle /api/v1/users/* {
        uri strip_prefix /api/v1
        reverse_proxy localhost:8002
    }
    handle /api/v1/billing/* {
        uri strip_prefix /api/v1
        reverse_proxy localhost:8012
    }
    handle /api/v1/live/* {
        uri strip_prefix /api/v1
        reverse_proxy localhost:8013
    }
    handle /api/v1/social/* {
        uri strip_prefix /api/v1
        reverse_proxy localhost:8014
    }
    handle /api/v1/notifications/* {
        uri strip_prefix /api/v1
        reverse_proxy localhost:8015
    }
    handle /api/v1/analytics/* {
        uri strip_prefix /api/v1
        reverse_proxy localhost:8016
    }

    # WebSocket upgrade paths
    handle /ws/live/* {
        reverse_proxy localhost:8113
    }
    handle /ws/party/* {
        reverse_proxy localhost:8114
    }

    # JWKS for token verification
    handle /.well-known/jwks.json {
        reverse_proxy localhost:8001
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options nosniff
        # CORS handled at the service level; just expose the headers
        Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
    }
}
